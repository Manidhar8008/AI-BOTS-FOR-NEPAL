# Shared local development settings.
# Copy to .env for local use; never commit real secrets.

# PostgreSQL stores tenants, scrape jobs, API key hashes, and ingestion metadata.
POSTGRES_USER=chatbot_admin
POSTGRES_PASSWORD=chatbot_admin_password
POSTGRES_DB=chatbot_saas
DATABASE_URL=postgresql+asyncpg://chatbot_admin:chatbot_admin_password@postgres:5432/chatbot_saas

# Redis backs async job queues and lightweight status polling fan-out.
REDIS_URL=redis://redis:6379/0

# Qdrant stores dense + sparse vectors with mandatory tenant payload filters.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=tenant_documents
EMBEDDING_DIMENSION=1536
DENSE_EMBEDDING_MODEL=text-embedding-3-small
SPARSE_EMBEDDING_MODEL=Qdrant/bm25

# MVP crawler guardrails.
MAX_CRAWL_PAGES=50
MAX_CRAWL_DEPTH=2
CRAWL_TIMEOUT_SECONDS=20
CRAWL_USER_AGENT=GovChatbotSaaSBot/0.1 (+https://example.com/bot)

# Provider keys are read from environment/secret manager, not from tenant tables.
OPENAI_API_KEY=
GEMINI_API_KEY=
CHAT_MODEL=gpt-4o-mini
CHAT_TEMPERATURE=0
CHAT_MAX_TOKENS=1200

# Cross-service URLs used by local Docker Compose.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_PUBLIC_BASE_URL=http://localhost:8000
